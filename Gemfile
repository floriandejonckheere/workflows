# Specify your gem's dependencies in workflows.gemspec
gemspec

# Behavior-driven testing framework [https://github.com/rspec/rspec-rails]
gem "rspec"
gem "rspec-rails"

# Shoulda-matchers [https://github.com/thoughtbot/shoulda-matchers]
gem "shoulda-matchers"

# Self-contained database system [https://sqlite.org/]
gem "sqlite3"

# Background job processing (required by the dummy Rails app in test/)
gem "solid_queue"

# The Ruby linter/formatter [https://github.com/rubocop/rubocop]
gem "rubocop"
gem "rubocop-performance"
gem "rubocop-rails"
gem "rubocop-rspec"
gem "rubocop-rspec_rails"
